# ============================================
# Hybrid LLM Routing Agent - Environment Config
# ============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# --- Local Model (Ollama) ---
# Host URL for your Ollama instance
OLLAMA_HOST=http://localhost:11434
# Local model to use (e.g., llama3.2:3b, llama3.2:1b, mistral:7b)
LOCAL_MODEL=llama3.2:3b

# --- Remote Model (Fireworks AI) ---
# Your Fireworks AI API key (get one at https://fireworks.ai)
# Leave blank to run in local-only / mocked-remote mode
FIREWORKS_API_KEY=
# Remote model identifier on Fireworks
REMOTE_MODEL=accounts/fireworks/models/llama-v3p1-70b-instruct
# Remote model price per 1M tokens (defaults to $0.90 for Llama 3.1 70B)
REMOTE_PRICE_PER_1M_TOKENS=0.90

# --- Optional: Self-Critique ---
# Enable the local model to self-critique its own responses.
# For small models (1B/3B), this is auto-disabled unless explicitly set to 'true'.
# For larger models (7B+), this is auto-enabled unless explicitly set to 'false'.
# ENABLE_LOCAL_CRITIQUE=true
